PORT=8080
NODE_ENV=development

# MongoDB Atlas - variable name: MONGODB_URI
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=<appName>

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
