# Cloud Run → Variables & secrets
# IMPORTANT: paste ONLY the URI value — no quotes, no "MONGODB_URI=" prefix

# IMPORTANT: include database name /milktea in the URI
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/milktea?retryWrites=true&w=majority&appName=bubbletea
JWT_SECRET=your-production-secret
JWT_EXPIRES_IN=7d
CORS_ORIGINS=*
NODE_ENV=production

# Cloud Run injects PORT automatically — do not override unless needed.
